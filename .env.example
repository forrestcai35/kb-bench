# Copy to .env and fill in the values. .env is gitignored.

# ---- Agent model (Anthropic, required for the agent under test) ----
# Get an API key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---- Judge panel (cross-family recommended) ----
# The benchmark defaults to a 3-judge panel: Claude + GPT + Gemini. If the
# candidate model is Claude, the Anthropic judge is dropped from the panel
# (BENCH_EXCLUDE_SAME_FAMILY_JUDGE=true). Adding at least one cross-family
# judge is a published best-practice for public benchmarks — see
# https://arxiv.org/abs/2404.18796 ("Replacing Judges with Juries").
OPENAI_API_KEY=
# Or route the OpenAI-family judge through OpenRouter's OpenAI-compatible API.
OPENROUTER_API_KEY=
# Google Gemini accepts either GOOGLE_API_KEY or GEMINI_API_KEY.
GOOGLE_API_KEY=
GEMINI_API_KEY=
# Free-tier Gemini keys can be pooled and rotated on quota exhaustion.
FREE_GEMINI_API_KEY_1=

# ---- Agent & judge tuning (optional) ----
# BENCH_MODEL=claude-sonnet-4-6                                  # candidate model (Opus 4.7 is 5x more expensive)
# BENCH_JUDGE_MODELS=claude-sonnet-4-6,gpt-5.4,gemini-3-pro      # panel, comma-separated
# BENCH_EXCLUDE_SAME_FAMILY_JUDGE=true                           # drop same-family judge for candidate
# BENCH_EFFORT=high                    # low | medium | high | xhigh | max
# BENCH_MAX_TOKENS=16000               # per-call max_tokens
# BENCH_MAX_TURNS=10                   # agent stop condition
# BENCH_RUNS=1                         # number of runs per (platform, query) pair
# BENCH_RETRIES=3                      # retries per API/tool call before giving up
# BENCH_TOP_K=5                        # default top-K used by search tools

# ---- Platform: Lore ----
# Reference adapter; disable by leaving LORE_API_KEY blank.
LORE_API_URL=
LORE_API_KEY=
LORE_WORKSPACE_ID=
# Direct-insert seeding bypasses the ingest API. These are optional unless
# you want to run `npm run seed -- --platform lore`.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
LORE_USER_ID=
LORE_BENCHMARK_FOLDER_NAME=Benchmarks
LORE_AUTHOR=kb-bench
LORE_CLI_API_KEY=

# ---- Platform: Notion ----
# Internal integration token from https://www.notion.so/profile/integrations.
# The integration must be shared with NOTION_PARENT_PAGE_ID.
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=

# ---- Platform: Confluence ----
# Atlassian Cloud site, e.g. https://yoursite.atlassian.net (no trailing slash).
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=
CONFLUENCE_SPACE_ID=
CONFLUENCE_PARENT_PAGE_ID=

# ---- Platform: Obsidian ----
# Requires the Local REST API community plugin
# (https://github.com/coddingtonbear/obsidian-local-rest-api) to be installed
# and enabled in the vault you want to benchmark. The plugin binds to loopback
# only, so this harness must run on the same machine as the Obsidian desktop
# app.
OBSIDIAN_API_URL=http://127.0.0.1:27123
OBSIDIAN_API_KEY=
OBSIDIAN_VAULT_FOLDER=Benchmarks
OBSIDIAN_INSECURE_TLS=false
