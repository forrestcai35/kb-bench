# Copy to .env and fill in the values. .env is gitignored.

# ---- Anthropic (required for `bench` and `judge`; not needed for `seed`) ----
# Provide ONE of the following. OAuth is preferred if you have Claude Max —
# requests count against your subscription instead of pay-per-token API credits.
#
# Option 1: OAuth token (Claude Max subscription).
# Grab the value from Claude Code (it logs in via OAuth under the hood) or
# generate one at https://console.anthropic.com. The benchmark also accepts
# CLAUDE_CODE_OAUTH_TOKEN if that's already set in your shell.
ANTHROPIC_AUTH_TOKEN=
# Option 2: API key. Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---- Agent tuning (optional) ----
# BENCH_MODEL=claude-opus-4-7
# BENCH_EFFORT=high             # low | medium | high | xhigh | max
# BENCH_MAX_TOKENS=16000
# BENCH_MAX_TURNS=10

# ---- Lore ----
# Default https://lightfield.app. Override if running against local dev.
LORE_API_URL=https://lightfield.app
# PAT from lore.app (Settings → API Keys). Used by the `bench` agent.
# Not required for `seed` — seeding uses the service role below.
LORE_API_KEY=
# UUID of the dedicated benchmark workspace. Keep it isolated from real data.
LORE_WORKSPACE_ID=

# ---- Lore: direct insert (seed only) ----
# Seeding bypasses the ingest API and inserts documents directly via Supabase
# service role, mirroring apps/blog-writer. Requires service-role access and a
# user_id to attribute the seeded rows to.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
LORE_USER_ID=
# Folder the seeded runbooks land in (created if missing).
LORE_BENCHMARK_FOLDER_NAME=Benchmarks
LORE_AUTHOR=Benchmark Seed
# Admin key for POST /api/admin/backfill-sections (same value as the
# LORE_CLI_API_KEY env var on the web server). Seed calls this after
# inserting rows so document_section / document_section_chunk get populated
# (embeddings via gemini-embedding-001). Without a valid key, seeded docs
# are invisible to search. Falls back to LORE_API_KEY if unset.
LORE_CLI_API_KEY=

# ---- Notion ----
# Internal integration token from https://www.notion.so/profile/integrations
# The integration must be explicitly shared with NOTION_PARENT_PAGE_ID.
NOTION_TOKEN=
# ID of a parent page to create the 20 runbooks under. Find it in the page URL
# (32-char hex after the page slug), or use the "Copy link to page" menu.
NOTION_PARENT_PAGE_ID=

# ---- Confluence ----
# Atlassian Cloud site, e.g. https://yoursite.atlassian.net (no trailing slash).
CONFLUENCE_BASE_URL=
# Email of the Atlassian account that owns the API token.
CONFLUENCE_EMAIL=
# API token from https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=
# Space KEY (not name) seeding + benchmark search are scoped to.
# Find it in the space URL: /wiki/spaces/<KEY>/...
# Personal spaces have keys beginning with ~ (e.g. ~712020abc...).
CONFLUENCE_SPACE_KEY=
# Optional: numeric space ID. Set this to bypass the key→id lookup if you hit
# 404s (can happen on some personal-space configurations).
CONFLUENCE_SPACE_ID=
# Optional: parent page ID to nest seeded runbooks under. Leave empty to
# create them at the space root.
CONFLUENCE_PARENT_PAGE_ID=

# ---- Obsidian ----
# Requires the Local REST API community plugin
# (https://github.com/coddingtonbear/obsidian-local-rest-api) to be installed
# and enabled in the vault you want to benchmark. The plugin binds to loopback
# only, so this harness must run on the same machine as the Obsidian desktop
# app.
#
# Recommended: enable "Enable Non-encrypted (HTTP) Server" in the plugin
# settings, which serves on port 27123 and avoids any self-signed-cert fuss.
# Alternatively, keep the default HTTPS server on port 27124 and set
# OBSIDIAN_INSECURE_TLS=true below so the adapter trusts the plugin's
# self-signed cert.
OBSIDIAN_API_URL=http://127.0.0.1:27123
# API key generated by the plugin. Find it in the plugin's settings tab.
OBSIDIAN_API_KEY=
# Vault-relative folder the seed script will write runbooks into (created if
# missing). Leave empty to seed at the vault root.
OBSIDIAN_VAULT_FOLDER=Benchmarks
# Set to "true" only when OBSIDIAN_API_URL starts with https:// and you're
# using the plugin's default self-signed cert. Toggles Node's TLS verification
# off for the localhost Obsidian requests only, around each call.
OBSIDIAN_INSECURE_TLS=false
