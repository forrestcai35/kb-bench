{
  "name": "kb-bench",
  "version": "0.2.0",
  "description": "An open benchmark for agentic knowledge-base retrieval. Measures, per query per platform, how many tokens a single LLM agent reads, how long it takes, how many tool calls it makes, and how correct its final answer is.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/forrestcai/kb-bench"
  },
  "keywords": [
    "benchmark",
    "knowledge-base",
    "rag",
    "retrieval",
    "agent",
    "llm",
    "notion",
    "confluence",
    "obsidian",
    "evaluation"
  ],
  "scripts": {
    "bench": "tsx src/index.ts",
    "judge": "tsx src/judge.ts",
    "report": "tsx src/report.ts",
    "seed": "tsx scripts/seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google/genai": "^0.7.0",
    "@notionhq/client": "^2.2.15",
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^17.4.2",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.4"
  }
}
